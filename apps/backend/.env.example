PORT=5000
NODE_ENV=development

# PostgreSQL (or use Supabase connection string)
DATABASE_URL=postgresql://user:password@localhost:5432/reachinbox_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT & Session
JWT_SECRET=your_jwt_secret_min_32_chars_here
SESSION_SECRET=your_session_secret_min_32_chars_here

# Google OAuth — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback

# Ethereal SMTP (optional — auto-created if blank)
ETHEREAL_USER=
ETHEREAL_PASS=

# Worker tuning
WORKER_CONCURRENCY=5
MAX_EMAILS_PER_HOUR=200
MAX_EMAILS_PER_HOUR_PER_SENDER=100
MIN_DELAY_BETWEEN_EMAILS=2000

# Frontend origin
FRONTEND_URL=http://localhost:3000
